# ══════════════════════════════════════════════════════════════
#  VERCEL ENVIRONMENT VARIABLES
#  Add in: Vercel Dashboard → Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Supabase PostgreSQL connection string ───────────────────
# Get from: Supabase Dashboard → Project Settings → Database
# → Connection String → URI tab → copy it, replace [YOUR-PASSWORD]
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── JWT Secrets ──────────────────────────────────────────────
JWT_SECRET=helpinghearts_user_jwt_secret_change_this_2024
JWT_ADMIN_SECRET=helpinghearts_admin_jwt_secret_change_this_2024
JWT_EXPIRES_IN=7d

# ── Admin panel secret URL ──────────────────────────────────
ADMIN_SECRET_PATH=your-own-secret-word-here
